// DOMUS+ Beta DBE — Schema F1 (validado)
// SQLite. Ajustes: WAL y busy_timeout se aplican al conectar (ver docs).
// UUID como String para compatibilidad SQLite.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// Tipos de entidad unificados (incluye FAMILIA raíz por hogar).
enum EntityKind {
  FAMILY
  PERSON
  ASSET
  PET
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String  @map("password_hash")
  name         String?
  phone        String?
  city         String?
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships  FamilyMember[]
  entityOwnerships EntityOwner[]
  entityPermissions UserEntityPermission[]
  budgetCategories BudgetCategory[]
  transactions Transaction[]
  receipts     Receipt[]
  receiptExtractions ReceiptExtraction[] @relation("ReceiptExtractionUser")
  receiptExtractionsConfirmed ReceiptExtraction[] @relation("ReceiptExtractionConfirmedBy")
  deletionArchivesCreated DeletionArchive[] @relation("DeletionArchiveCreatedBy")
  deletionArchivesDeleted DeletionArchive[] @relation("DeletionArchiveDeletedBy")
  moneyRequestsCreated MoneyRequest[] @relation("MoneyRequestCreatedBy")
  moneyRequestsApproved MoneyRequest[] @relation("MoneyRequestApprovedBy")
  moneyRequestsRejected MoneyRequest[] @relation("MoneyRequestRejectedBy")
  passwordResetTokens PasswordResetToken[]
  documents UserDocument[]
  things   UserThing[]
}

model UserDocument {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  category      String    // ej. IDENTIFICACIONES, ACTAS, VEHICULOS, MOTOCICLETAS (el usuario puede crear categorías)
  name          String?   // etiqueta (ej. "INE", "Acta de nacimiento")
  fileUrl       String    @map("file_url")
  fileName      String    @map("file_name")
  contentType   String?   @map("content_type")
  thumbnailUrl  String?   @map("thumbnail_url")   // miniatura ~1x1 pulgada para lista
  extractedData Json?     @map("extracted_data")  // datos extraídos (nombre, número, fecha vencimiento, etc.) ordenados
  expiresAt     DateTime? @map("expires_at")      // fecha de vencimiento (identificaciones, licencias)
  reminderLastSentAt DateTime? @map("reminder_last_sent_at")  // último recordatorio por WhatsApp (vencimiento)
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_documents")
}

model UserThing {
  id                    String    @id @default(uuid())
  userId                String    @map("user_id")
  type                  String    // DISPOSITIVO, AUTO, BICICLETA, SERVICIO_INTERNET, VISITA_MEDICA, OTRO
  name                  String    // ej. "Mi laptop", "Carro", "Internet de casa"
  brand                 String?   @map("brand")
  model                 String?   @map("model")
  serialNumber          String?   @map("serial_number")
  acquisitionDate       DateTime? @map("acquisition_date")
  invoiceUrl            String?   @map("invoice_url")
  warrantyInfo          String?   @map("warranty_info")
  serviceProviderContact String?  @map("service_provider_contact")
  notes                 String?   @map("notes")
  extraJson             Json?     @map("extra_json")   // placas, llantas marca/modelo, monto mensual, etc.
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user     User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  records  UserThingMaintenanceRecord[]

  @@map("user_things")
}

model UserThingMaintenanceRecord {
  id            String    @id @default(uuid())
  userThingId   String    @map("user_thing_id")
  recordType    String    @map("record_type")   // SERVICIO, MANTENIMIENTO, PAGO, VISITA_MEDICA, CAMBIO_LLANTAS, etc.
  date          DateTime  @map("date")
  nextDueDate   DateTime? @map("next_due_date")
  amount        String?   @map("amount")
  description   String?   @map("description")
  imageUrl      String?   @map("image_url")
  createdAt     DateTime  @default(now()) @map("created_at")

  thing UserThing @relation(fields: [userThingId], references: [id], onDelete: Cascade)

  @@map("user_thing_maintenance_records")
}

model Family {
  id               String   @id @default(uuid())
  name             String
  currency         String   @default("MXN")
  cutoffDay        Int      @default(1) @map("cutoff_day")
  budgetStartDate  DateTime @map("budget_start_date")
  setupComplete    Boolean  @default(false) @map("setup_complete")
  planStatus       String   @default("DRAFT") @map("plan_status")
  inventoryJson    Json?    @map("inventory_json")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  members           FamilyMember[]
  entities          Entity[]
  entityServices    EntityService[]
  customEntityTypes FamilyEntityType[]
  entityOwners      EntityOwner[]
  budgetCategories  BudgetCategory[]
  budgetAccounts    BudgetAccount[]
  transactions      Transaction[]
  receipts          Receipt[]
  receiptExtractions ReceiptExtraction[]
  moneyRequests    MoneyRequest[]
  categorySuggestions CategorySuggestion[]
  categoryPreferences FamilyCategoryPreference[]
  budgetAdjustmentSuggestions BudgetAdjustmentSuggestion[]
  userBudgetSubdivisions UserBudgetSubdivision[]
  userEntityPermissions UserEntityPermission[]
  calendarEvents FamilyCalendarEvent[]
  invites FamilyInvite[]
  assets FamilyAsset[]
}

// Activos del hogar (electrodomésticos, vehículos): inventario con fotos y videos en storage.
model FamilyAsset {
  id            String   @id @default(uuid())
  familyId      String   @map("family_id")
  type          String   // ARTICLE | VEHICLE
  name          String
  inventoryCode String?  @map("inventory_code") // ej. TVS-ALF
  marca         String?
  modelo        String?
  year          String?
  serialNumber String?  @map("serial_number")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  family Family             @relation(fields: [familyId], references: [id], onDelete: Cascade)
  media  FamilyAssetMedia[]

  @@map("family_assets")
}

// Fotos (3-10) y videos (2) por activo; URL apunta a storage (Spaces).
model FamilyAssetMedia {
  id        String   @id @default(uuid())
  assetId   String   @map("asset_id")
  kind      String   // PHOTO | VIDEO
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  asset FamilyAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("family_asset_media")
}

model FamilyMember {
  id             String   @id @default(uuid())
  familyId       String   @map("family_id")
  userId         String   @map("user_id")
  isFamilyAdmin  Boolean  @default(false) @map("is_family_admin")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@map("family_members")
}

model FamilyInvite {
  id        String   @id @default(uuid())
  familyId  String   @map("family_id")
  code      String   @unique
  expiresAt DateTime? @map("expires_at")
  createdByUserId String? @map("created_by_user_id")
  createdAt DateTime @default(now()) @map("created_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  @@map("family_invites")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("password_reset_tokens")
}

// Tipos de partida personalizados por familia (ej. Electrodoméstico, Negocio). Complementan ASSET/PET vía customTypeId.
model FamilyEntityType {
  id        String   @id @default(uuid())
  familyId  String   @map("family_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  family   Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  entities Entity[]

  @@unique([familyId, name])
  @@map("family_entity_types")
}

/// Entidad base unificada (Familia raíz + personas + activos + mascotas).
model Entity {
  id           String   @id @default(uuid())
  familyId     String   @map("family_id")
  type         EntityKind
  customTypeId String?  @map("custom_type_id")
  name         String
  subtype      String?
  parentId     String?  @map("parent_id")
  ownerEntityId String? @map("owner_entity_id")
  imageUrl     String?  @map("image_url")
  isActive     Boolean  @default(true) @map("is_active")
  participatesInBudget  Boolean @default(true) @map("participates_in_budget")
  participatesInReports Boolean @default(true) @map("participates_in_reports")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  family      Family            @relation(fields: [familyId], references: [id], onDelete: Cascade)
  customType  FamilyEntityType? @relation(fields: [customTypeId], references: [id], onDelete: SetNull)
  parent      Entity?           @relation("EntityHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Entity[]          @relation("EntityHierarchy")
  ownerEntity Entity?           @relation("EntityOwnership", fields: [ownerEntityId], references: [id], onDelete: SetNull)
  ownedThings Entity[]          @relation("EntityOwnership")
  entityServices EntityService[]
  budgetAccounts BudgetAccount[]
  owners      EntityOwner[]
  permissionsGranted UserEntityPermission[]
  moneyRequestsFor MoneyRequest[]

  @@index([familyId, type])
  @@map("entities")
}

model EntityOwner {
  id        String   @id @default(uuid())
  familyId  String   @map("family_id")
  entityId  String   @map("entity_id")
  userId    String   @map("user_id")
  sharePct  Int?     @map("share_pct")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entityId, userId])
  @@map("budget_entity_owners")
}

/// Catálogo global de servicios (sin texto libre como destino).
model Service {
  id             String   @id @default(uuid())
  name           String   @unique
  categoryGroup  String?  @map("category_group")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  entityServices EntityService[]
  budgetAccounts BudgetAccount[]

  @@map("services")
}

/// Servicio habilitado para una entidad dentro de una familia.
model EntityService {
  id         String   @id @default(uuid())
  familyId   String   @map("family_id")
  entityId   String   @map("entity_id")
  serviceId  String   @map("service_id")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  family  Family  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  entity  Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([entityId, serviceId])
  @@map("entity_services")
}

/// Destino presupuestal = entidad + servicio (cuenta con límite mensual).
model BudgetAccount {
  id                   String   @id @default(uuid())
  familyId             String   @map("family_id")
  entityId             String   @map("entity_id")
  serviceId            String   @map("service_id")
  monthlyLimit         Decimal  @default(0) @map("monthly_limit")
  isActive             Boolean  @default(true) @map("is_active")
  defaultPaymentMethod String?  @map("default_payment_method")
  bankAccountLabel     String?  @map("bank_account_label")
  providerClabe        String?  @map("provider_clabe")
  providerReference    String?  @map("provider_reference")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  family       Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  entity       Entity        @relation(fields: [entityId], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  transactions Transaction[]
  moneyRequests MoneyRequest[]
  subdivisions UserBudgetSubdivision[]

  @@unique([entityId, serviceId])
  @@map("budget_accounts")
}

/// Permisos por usuario sobre entidades (vista / gastar / mover).
model UserEntityPermission {
  id          String   @id @default(uuid())
  familyId    String   @map("family_id")
  userId      String   @map("user_id")
  entityId    String   @map("entity_id")
  canView     Boolean  @default(true) @map("can_view")
  canSpend    Boolean  @default(false) @map("can_spend")
  canMove     Boolean  @default(false) @map("can_move")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId])
  @@map("user_entity_permissions")
}

model BudgetCategory {
  id        String   @id @default(uuid())
  familyId  String   @map("family_id")
  userId    String?  @map("user_id")   // null = familia; si set = partidas del entorno de ese usuario
  type      String
  name      String
  code      String?  // ej. 6110, 7100 (para partidas jerárquicas)
  parentId  String?  @map("parent_id") // categoría padre (mismo familyId+userId)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  family      Family                     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user        User?                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      BudgetCategory?            @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    BudgetCategory[]           @relation("CategoryParent")
  preferences FamilyCategoryPreference[]

  @@unique([familyId, userId, code])
  @@map("budget_categories")
}

model FamilyCategoryPreference {
  id          String   @id @default(uuid())
  familyId    String   @map("family_id")
  categoryId  String   @map("category_id")
  preferenceKey String @map("preference_key") // comercio o concepto normalizado (ej. "farmacias del ahorro")
  createdAt   DateTime @default(now()) @map("created_at")

  family   Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  category BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([familyId, preferenceKey])
  @@map("family_category_preferences")
}

model CategorySuggestion {
  id                  String    @id @default(uuid())
  familyId            String    @map("family_id")
  suggestedName       String    @map("suggested_name")
  exampleMerchant     String?   @map("example_merchant")
  status              String    @default("PENDING") // PENDING | APPROVED | REJECTED
  outboundMessageSid  String?   @map("outbound_message_sid")
  createdAt           DateTime  @default(now()) @map("created_at")
  resolvedAt          DateTime? @map("resolved_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("category_suggestions")
}

model BudgetAdjustmentSuggestion {
  id          String   @id @default(uuid())
  familyId    String   @map("family_id")
  userId      String   @map("user_id")
  type        String   // SUBDIVIDE_CATEGORY | CHANGE_LIMIT | NEW_CATEGORY | OTHER
  payload     String   // JSON: { categoryId?, categoryName?, allocationId?, newLimit?, suggestedName?, text? }
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  resolvedAt  DateTime? @map("resolved_at")
  resolvedBy  String?  @map("resolved_by") // userId of admin who resolved
  createdAt   DateTime @default(now()) @map("created_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("budget_adjustment_suggestions")
}

model UserBudgetSubdivision {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  familyId         String   @map("family_id")
  budgetAccountId  String   @map("budget_account_id")
  name             String
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")

  family       Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  budgetAccount BudgetAccount @relation(fields: [budgetAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, familyId, budgetAccountId, name])
  @@map("user_budget_subdivisions")
}

model Transaction {
  id               String   @id @default(uuid())
  familyId         String   @map("family_id")
  userId           String   @map("user_id")
  budgetAccountId  String   @map("budget_account_id")
  amount           Decimal
  date             DateTime
  description      String?
  registrationCode String?  @map("registration_code")
  pendingReason    String?  @map("pending_reason")
  /// manual | ticket | whatsapp | import (legacy: source_channel podía ser app/email)
  source           String   @default("manual")
  sourceChannel    String?  @map("source_channel")
  paymentMethod    String?  @map("payment_method")
  conceptDetail    String?  @map("concept_detail")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  family        Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetAccount BudgetAccount @relation(fields: [budgetAccountId], references: [id], onDelete: Restrict)
  receipts      Receipt[]
  moneyRequest  MoneyRequest?

  @@unique([familyId, registrationCode])
  @@map("transactions")
}

model Receipt {
  id            String   @id @default(uuid())
  transactionId String   @map("transaction_id")
  userId        String   @map("user_id")
  familyId      String   @map("family_id")
  fileUrl       String   @map("file_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  family      Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  images      ReceiptImage[]
  extraction  ReceiptExtraction?

  @@map("receipts")
}

model ReceiptImage {
  id        String   @id @default(uuid())
  receiptId String   @map("receipt_id")
  fileUrl   String   @map("file_url")
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  receipt   Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@unique([receiptId, sortOrder])
  @@map("receipt_images")
}

model ReceiptExtraction {
  id           String   @id @default(uuid())
  receiptId    String   @unique @map("receipt_id")
  familyId     String   @map("family_id")
  userId       String   @map("user_id")
  confirmedAt  DateTime? @map("confirmed_at")
  confirmedByUserId String? @map("confirmed_by_user_id")

  merchantName String?  @map("merchant_name")
  receiptDate  DateTime? @map("receipt_date")
  total        Decimal? // total a pagar (bloqueado; no editable)
  currency     String?  // ISO 4217 (ej. MXN)
  tax          Decimal?
  tip          Decimal?

  rawText      String?  @map("raw_text")
  rawJson      String?  @map("raw_json")
  metaJson     String?  @map("meta_json")

  // Consumo (recibos de luz/agua): tipo, cantidad, unidad, periodo
  receiptType           String?   @map("receipt_type")   // "utility" | "retail"
  consumptionQuantity   Decimal?  @map("consumption_quantity")
  consumptionUnit       String?   @map("consumption_unit")   // "kWh", "m3", etc.
  consumptionPeriodStart DateTime? @map("consumption_period_start")
  consumptionPeriodEnd   DateTime? @map("consumption_period_end")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  receipt      Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  family       Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user         User     @relation("ReceiptExtractionUser", fields: [userId], references: [id], onDelete: Cascade)
  confirmedBy  User?    @relation("ReceiptExtractionConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  items        ReceiptExtractionItem[]

  @@map("receipt_extractions")
}

model ReceiptExtractionItem {
  id           String   @id @default(uuid())
  extractionId String   @map("extraction_id")
  lineNumber   Int      @map("line_number")

  description  String
  rawLine      String?  @map("raw_line")

  quantity     Decimal?
  unitPrice    Decimal? @map("unit_price")
  amount       Decimal?

  isAdjustment Boolean  @default(false) @map("is_adjustment")
  isPlaceholder Boolean @default(false) @map("is_placeholder")
  lineType     String?  @map("line_type")
  notesJson    String?  @map("notes_json")
  quantityUnit String?  @map("quantity_unit")   // "g", "kg", "L", "ml", "unidades"

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  extraction   ReceiptExtraction @relation(fields: [extractionId], references: [id], onDelete: Cascade)

  @@unique([extractionId, lineNumber])
  @@map("receipt_extraction_items")
}

// Solicitud de efectivo (flujo app + WhatsApp).
model MoneyRequest {
  id                  String    @id @default(uuid())
  familyId            String    @map("family_id")
  createdByUserId     String    @map("created_by_user_id")
  requestedAt         DateTime  @default(now()) @map("requested_at")
  forEntityId         String?   @map("for_entity_id")
  forName             String?   @map("for_name")
  budgetAccountId     String?   @map("budget_account_id")
  date                DateTime  @map("date")
  reason              String    @map("reason")
  amount              Decimal   @map("amount")
  currency            String    @default("MXN") @map("currency")
  status              String    @map("status")   // PENDING | APPROVED | REJECTED | DELIVERED
  transactionId       String?   @unique @map("transaction_id")
  registrationCode    String?   @map("registration_code")   // S-XXXX único por familia
  outboundMessageSid  String?   @map("outbound_message_sid")
  approvedAt          DateTime? @map("approved_at")
  approvedByUserId    String?   @map("approved_by_user_id")
  rejectedAt          DateTime? @map("rejected_at")
  rejectedByUserId    String?   @map("rejected_by_user_id")
  deliveredAt         DateTime? @map("delivered_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  family       Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("MoneyRequestCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  forEntity    Entity? @relation(fields: [forEntityId], references: [id], onDelete: SetNull)
  budgetAccount BudgetAccount? @relation(fields: [budgetAccountId], references: [id], onDelete: SetNull)
  transaction  Transaction?  @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  approvedBy   User?         @relation("MoneyRequestApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejectedBy   User?         @relation("MoneyRequestRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)

  lastReminderAt   DateTime? @map("last_reminder_at")
  @@unique([familyId, registrationCode])
  @@map("money_requests")
}

// Eventos de calendario no financieros (cumpleaños, recordatorios, vacaciones, etc.).
model FamilyCalendarEvent {
  id          String   @id @default(uuid())
  familyId    String   @map("family_id")
  title       String
  eventDate   DateTime @map("event_date")
  type        String   @default("custom") // birthday | appointment | reminder | vacation | custom
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("family_calendar_events")
}

// SID del mensaje WhatsApp de confirmación de recibo (para vincular respuestas "es para Sofía").
model ReceiptConfirmationMessage {
  id            String   @id @default(uuid())
  messageSid    String   @unique @map("message_sid")
  transactionId String   @map("transaction_id")
  familyId      String   @map("family_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("receipt_confirmation_messages")
}

// Respaldo oculto antes de eliminaciones (no se muestra en UI).
model DeletionArchive {
  id              String   @id @default(uuid())
  kind            String
  familyId        String?  @map("family_id")
  familyName      String?  @map("family_name")
  createdByUserId String?  @map("created_by_user_id")
  deletedAt       DateTime? @map("deleted_at")
  deletedByUserId String?  @map("deleted_by_user_id")

  payloadJson     String   @map("payload_json")
  payloadSha256   String?  @map("payload_sha256")

  spacesKey       String?  @map("spaces_key")
  spacesUrl       String?  @map("spaces_url")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdBy       User?    @relation("DeletionArchiveCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  deletedBy       User?    @relation("DeletionArchiveDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@map("deletion_archives")
}
