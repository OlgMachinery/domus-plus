# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # En Dashboard: API → anon public (para login y cliente)
# Clave service role (solo servidor; necesaria para /register, seed-test-user, crear integrantes)
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # En Dashboard: API → service_role (secreta)
# Opcional: si usas otro nombre
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=...
# SUPABASE_SECRET_KEY=...   # alias de SERVICE_ROLE_KEY en algunos proyectos

# OpenAI Configuration (for receipt OCR processing)
OPENAI_API_KEY=your_openai_api_key_here

# Twilio Configuration (for WhatsApp integration)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_whatsapp_number
